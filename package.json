{
  "name": "artist-tier-list",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Drag-and-drop tier list for musical artists",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "enrich": "tsx scripts/enrich-images.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "dependencies": {
    "sortablejs": "^1.15.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/sortablejs": "^1.15.8",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
